rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // arquivos públicos do site
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // banners públicos
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // imagens de produtos por seller
    match /products/{sellerUid}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(sellerUid);
    }

    // fallback para produtos gerais
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // arquivos de usuário privados
    match /users/{userId}/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // bloqueio do resto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}